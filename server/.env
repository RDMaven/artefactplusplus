# .env : Définit les variables globales du projet, coté serveur.

# GENERAL
APP_NAME=Artefact+++

# WEBSERVER : Pour l'application web de contrôle des robots.
WEB_PORT=8081
WEB_HOST=0.0.0.0
STATIC_DIRECTORY='sites/www/assets/'
TEMPLATES_DIRECTORY='sites/www/pages/'
MAPS_DIRECTORY='sites/MAP_CONSTRUCTOR_2.0/CARTES/'

# Explication complémentaire
# - WEB_HOST : On mets 0.0.0.0 (IPv4) (resp. [::] (IPv6)) pour que le site soit accessible par tout appareil 
#              sur le réseau du serveur, en tappant l'adresse IPv4 (resp. IPv6) du serveur.